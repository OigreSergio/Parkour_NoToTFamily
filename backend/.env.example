# Copy to .env and fill in. Never commit .env.

ENV=development
DEBUG=true

# Database (use postgresql+asyncpg://... for asyncpg driver)
DATABASE_URL=postgresql+asyncpg://parkour:parkour@localhost:5432/parkour

# Redis (chat pub/sub, rate limiting cache)
REDIS_URL=redis://localhost:6379/0

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# CORS — comma-separated origins for the mobile/web clients
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Object storage for spot photos (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=parkour-spots
S3_REGION=eu-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Initial admin user, created on first migration if not exists
INITIAL_ADMIN_EMAIL=admin@notot.family
INITIAL_ADMIN_PASSWORD=
